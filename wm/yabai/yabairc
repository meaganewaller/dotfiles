  Qt Creator
  Visual Studio Code
  Visual Studio
  XCode
)

for ((i = 1; i <= "${#CODE[@]}"; i++)); do
	yabai -m rule --add label="code_${CODE[(($i - 1))]}" app="^${CODE[(($i - 1))]}.*$" space=code
done

# Keep yabai up to date automatically
#YABAI_CERT=yabai-cert sh -c ~/.config/yabai/scripts/update.sh &

echo "yabai configuration loaded.."






