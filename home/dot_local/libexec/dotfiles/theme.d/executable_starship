#!/bin/sh
# theme.d/starship — render a full starship config overlay with the active
# palette pinned.
#
# starship has no STARSHIP_PALETTE env var and no config include mechanism;
# the only way to pin a palette at runtime is to point STARSHIP_CONFIG at a
# complete config that sets `palette = "…"`. The shell rcfiles do that
# export when this overlay exists.
#
# The overlay is regenerated on every theme switch (and on every chezmoi
# apply via verify-theme-registry) so it tracks edits to the base config.

set -eu

theme="${1:-}"
if [ -z "$theme" ]; then
  echo "theme.d/starship: missing theme name argument" >&2
  exit 64
fi

palette=$("$HOME/.local/libexec/dotfiles/theme-lookup" starship "$theme")

base="${XDG_CONFIG_HOME:-$HOME/.config}/starship.toml"
if [ ! -r "$base" ] ; then
  echo "theme.d/starship: base config not found at $base" >&2
  exit 65
fi

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/theme"
mkdir -p "$state_dir"
overlay="$state_dir/starship.toml"

tmp="${overlay}.tmp"
{
  printf '# Generated by theme.d/starship — do not edit. Re-run `theme <name>`.\n'
  printf 'palette = "%s"\n\n' "$palette"
  # Strip any existing top-level `palette = …` line from the base so the
  # prepended override is authoritative.
  sed -E '/^palette[[:space:]]*=/d' "$base"
} > "$tmp"
mv "$tmp" "$overlay"
