#!/bin/sh
# theme.d/sketchybar — write a sketchybar color overlay and hot-reload the bar.
#
# Sketchybar's rcfile sources this overlay (when present) to pin its palette.
# We export sketchybar's 0xAARRGGBB color hexes as env vars so the rcfile can
# splice them into `--bar` and `--default` directives without re-parsing them.

set -eu

theme="${1:-}"
if [ -z "$theme" ]; then
  echo "theme.d/sketchybar: missing theme name argument" >&2
  exit 64
fi

token=$("$HOME/.local/libexec/dotfiles/theme-lookup" sketchybar "$theme")

case "$token" in
  catppuccin-mocha)
    # base 1e1e2e · surface0 313244 · text cdd6f4 · pink f5c2e7 · mauve cba6f7
    bar=0xcc1e1e2e
    item_bg=0xff313244
    fg=0xffcdd6f4
    accent=0xfff5c2e7
    accent_alt=0xffcba6f7
    ;;
  catppuccin-latte)
    # base eff1f5 · surface0 ccd0da · text 4c4f69 · pink ea76cb · mauve 8839ef
    bar=0xcceff1f5
    item_bg=0xffccd0da
    fg=0xff4c4f69
    accent=0xffea76cb
    accent_alt=0xff8839ef
    ;;
  *)
    echo "theme.d/sketchybar: no palette implementation for token '$token'" >&2
    exit 65
    ;;
esac

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/theme"
mkdir -p "$state_dir"
overlay="$state_dir/sketchybar.sh"

tmp="${overlay}.tmp"
cat > "$tmp" <<EOF
# Generated by theme.d/sketchybar — do not edit. Re-run \`theme <name>\`.
export COLOR_BAR=$bar
export COLOR_ITEM_BG=$item_bg
export COLOR_FG=$fg
export COLOR_ACCENT=$accent
export COLOR_ACCENT_ALT=$accent_alt
EOF
mv "$tmp" "$overlay"

if command -v sketchybar >/dev/null 2>&1; then
  sketchybar --reload >/dev/null 2>&1 || true
fi
