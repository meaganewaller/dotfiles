#!/bin/sh
# theme.d/ghostty — write a Ghostty config overlay containing only `theme = …`.
#
# Ghostty's own config.tmpl includes this file via `config-file = …`. Ghostty
# does not auto-reload on overlay changes, so active windows need a manual
# reload (cmd+shift+, on macOS) to pick up the new theme. New windows pick it
# up at launch.

set -eu

theme="${1:-}"
if [ -z "$theme" ]; then
  echo "theme.d/ghostty: missing theme name argument" >&2
  exit 64
fi

ghostty_theme=$("$HOME/.local/libexec/dotfiles/theme-lookup" ghostty "$theme")

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/theme"
mkdir -p "$state_dir"
overlay="$state_dir/ghostty.conf"

tmp="${overlay}.tmp"
printf 'theme = %s\n' "$ghostty_theme" > "$tmp"
mv "$tmp" "$overlay"
