#!/usr/bin/env lua
-- sketchybar — whimsical pixel-font menu bar (SbarLua).
--
-- This config drives sketchybar through SbarLua (https://github.com/FelixKratz/SbarLua):
-- the compiled module lives at ~/.local/share/sketchybar_lua/sketchybar.so (built by
-- the run_onchange_after_install-sketchybar-lua script from the pinned external source).
-- The interpreter is brew's `lua` (5.5.x), whose ABI matches SbarLua's vendored Lua.
--
-- Colors come from the universal theme switcher's runtime overlay at
-- $XDG_STATE_HOME/theme/sketchybar.lua (see ADR-0006). That file `return`s a table of
-- 0xAARRGGBB color strings; the defaults below match catppuccin-mocha so a fresh machine
-- that never ran `theme <name>` still gets a coherent palette.
--
-- Reload after edits or theme switches:  sketchybar --reload

local home = os.getenv("HOME")

-- Locate the SbarLua module, then load it.
package.cpath = package.cpath .. ";" .. home .. "/.local/share/sketchybar_lua/?.so"
local sbar = require("sketchybar")

-- ── palette defaults (catppuccin-mocha) ────────────────────────────────────
-- base @ ~80% alpha · surface0 · text · pink · mauve
local colors = {
  bar        = "0xcc1e1e2e",
  item_bg    = "0xff313244",
  fg         = "0xffcdd6f4",
  accent     = "0xfff5c2e7",
  accent_alt = "0xffcba6f7",
}

-- ── theme overlay override ─────────────────────────────────────────────────
local state = os.getenv("XDG_STATE_HOME") or (home .. "/.local/state")
local overlay = loadfile(state .. "/theme/sketchybar.lua")
if overlay then
  local ok, palette = pcall(overlay)
  if ok and type(palette) == "table" then
    for key, value in pairs(palette) do
      colors[key] = value
    end
  end
end

-- ── fonts ──────────────────────────────────────────────────────────────────
local FONT_LABEL = "Pixelify Sans:Medium:13.0"
local FONT_ICON  = "Pixelify Sans:Bold:14.0"

-- ── bar ──────────────────────────────────────────────────────────────────
sbar.bar({
  position      = "top",
  height        = 30,
  blur_radius   = 24,
  color         = colors.bar,
  padding_left  = 8,
  padding_right = 8,
  corner_radius = 0,
  margin        = 0,
  sticky        = "on",
})

-- ── item defaults ──────────────────────────────────────────────────────────
sbar.default({
  updates = "when_shown",
  icon = {
    font          = FONT_ICON,
    color         = colors.accent,
    padding_left  = 8,
    padding_right = 4,
  },
  label = {
    font          = FONT_LABEL,
    color         = colors.fg,
    padding_left  = 4,
    padding_right = 8,
  },
  background = {
    color         = colors.item_bg,
    corner_radius = 6,
    height        = 22,
  },
  padding_left  = 3,
  padding_right = 3,
})

-- ── right side (added right-to-left in render order) ────────────────────────

-- battery — pixel-block icon scales with charge; charging swaps to a bolt.
local battery = sbar.add("item", "battery", {
  position    = "right",
  update_freq = 30,
})

local function update_battery()
  local handle = io.popen("pmset -g batt")
  if not handle then
    battery:set({ icon = "▢", label = "??" })
    return
  end
  local raw = handle:read("*a")
  handle:close()

  local percent = tonumber(raw:match("(%d+)%%"))
  if not percent then
    battery:set({ icon = "▢", label = "??" })
    return
  end

  local icon
  if raw:find("AC Power") then icon = "⚡"
  elseif percent >= 90 then    icon = "█"
  elseif percent >= 70 then    icon = "▇"
  elseif percent >= 50 then    icon = "▅"
  elseif percent >= 30 then    icon = "▃"
  elseif percent >= 10 then    icon = "▂"
  else                         icon = "▁"
  end

  battery:set({ icon = icon, label = percent .. "%" })
end

battery:subscribe({ "routine", "system_woke", "power_source_change" }, update_battery)

-- sparkle separator between battery and clock
sbar.add("item", "sparkle.r", {
  position = "right",
  label = {
    string        = "✦",
    color         = colors.accent_alt,
    padding_left  = 2,
    padding_right = 2,
  },
  background = { drawing = "off" },
  icon       = { drawing = "off" },
})

-- clock — "Tuesday May 26th 1:25PM"
local clock = sbar.add("item", "clock", {
  position    = "right",
  update_freq = 10,
  icon        = "⋆",
})

local function update_clock()
  -- BSD/macOS strftime has no ordinal-suffix specifier, so compute it here.
  local day = tonumber(os.date("%d"))
  local suffix
  if day >= 11 and day <= 13 then suffix = "th"
  elseif day % 10 == 1 then       suffix = "st"
  elseif day % 10 == 2 then       suffix = "nd"
  elseif day % 10 == 3 then       suffix = "rd"
  else                            suffix = "th"
  end

  local hour = tonumber(os.date("%I")) -- strip the leading zero
  local label = os.date("%A %B ") .. day .. suffix .. " " .. hour .. os.date(":%M%p")
  clock:set({ label = label })
end

clock:subscribe("routine", update_clock)

-- Render once immediately so items show before their first periodic tick.
update_battery()
update_clock()

sbar.update()

-- Keep the Lua process alive to service event callbacks (required by SbarLua).
sbar.event_loop()
