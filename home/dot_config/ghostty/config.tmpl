# Ghostty Configuration
#
# Reload while running: cmd+shift+,
# Open this file:       cmd+, (the actual version)
# Command palette:      cmd+shift+p (search any action)
# Full reference:       https://ghostty.org/docs/config/reference
#
# Tip: Ghostty's macOS defaults already cover most useful keybinds
# (splits, tabs, fullscreen, jump-to-prompt, font sizing, equalize
# splits, toggle split zoom, etc.). Don't re-bind unless you want
# something different. See `ghostty +list-keybinds` for the list.

# --- Auto Update -------------------------------------------------------------
auto-update-channel = {{ .ghostty.auto_update_channel | default "stable" }}

# --- Typography --------------------------------------------------------------
{{ if eq .chezmoi.os "linux" -}}
window-decoration = false
{{- end }}

font-family = {{ .ghostty.font_family | default "Maple Mono NF CN" }}
font-family-bold = {{ .ghostty.font_family_bold | default "Maple Mono NF CN Bold" }}
font-family-italic = {{ .ghostty.font_family_italic | default "Maple Mono NF CN Italic" }}
font-family-bold-italic = {{ .ghostty.font_family_bold_italic | default "Maple Mono NF CN Bold Italic" }}
bold-is-bright = true
font-thicken = false
link-url = true
font-size = {{ .ghostty.font_size | default 13.6 }}
font-feature = +calt
font-feature = +liga
font-feature = +ss02
adjust-cell-height = 2

# --- Theme -------------------------------------------------------------------
theme = dark:Catppuccin Mocha,light:Catppuccin Latte
background-image = {{ .ghostty.background_image | default "~/.config/ghostty/bg/cyber-y2k-anime-desktop-wallpapers.png" }}
background-image-opacity = {{ .ghostty.background_image_opacity | default 0.15 }}
background-image-fit = cover
background = {{ .ghostty.background | default "#1f1b2e" }}
foreground = {{ .ghostty.foreground | default "#f8f5ff" }}
cursor-color = {{ .ghostty.cursor_color | default "#f5c2e7" }}
cursor-style = bar
cursor-style-blink = false
selection-background = {{ .ghostty.selection_background | default "#3b3555" }}
selection-foreground = {{ .ghostty.selection_foreground | default "#f8f5ff" }}

{{ if eq .chezmoi.os "darwin" }}
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = left
macos-window-shadow = true
{{ end }}

custom-shader-animation = true
custom-shader = shaders/cursor_slash.glsl
custom-shader = shaders/cursor_smear.glsl
quick-terminal-position = bottom
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15
scrollback-limit = 25000000

# Custom pastel ANSI palette
palette = 0=#2a243f
palette = 1=#ff7aa2
palette = 2=#b8f28f
palette = 3=#ffd480
palette = 4=#8bb8ff
palette = 5=#f6a8ff
palette = 6=#8fe9ff
palette = 7=#efe9ff
palette = 8=#6a6284
palette = 9=#ff95b7
palette = 10=#c9f7a8
palette = 11=#ffe0a3
palette = 12=#a9cbff
palette = 13=#f9beff
palette = 14=#aaf2ff
palette = 15=#ffffff

minimum-contrast = 1.1
background-opacity = {{ .ghostty.background_opacity | default 0.94 }}
background-opacity-cells = true
background-blur = {{ .ghostty.background_blur | default 20 }}

{{ if eq .chezmoi.os "darwin" }}
# Subtle translucency + blur on macOS.
background-opacity = 0.96
background-blur = 20
unfocused-split-opacity = 0.85
{{ end }}

# --- Window & Layout ---------------------------------------------------------
window-padding-x = {{ .ghostty.window_padding_x | default 10 }}
window-padding-y = {{ .ghostty.window_padding_y | default 8 }}
window-theme = auto
window-padding-balance = true
window-save-state = always
window-colorspace = display-p3
window-inherit-working-directory = true
window-inherit-font-size = true
window-padding-color = extend
window-vsync = true
window-height = {{ .ghostty.window_height | default 30 }}
window-width = {{ .ghostty.window_width | default 110 }}


# --- Cursor, mouse, selection ------------------------------------------------
cursor-style = block
cursor-style-blink = true
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true
copy-on-select = clipboard

# --- Security ----------------------------------------------------------------
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# --- Shell Integration -------------------------------------------------------
shell-integration = detect

