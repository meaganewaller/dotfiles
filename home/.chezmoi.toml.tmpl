# Chezmoi Configuration File Template
# This template is processed during `chezmoi init` to create the actual config file.
# Variables are prompted from the user and stored in the [data] section.

{{- $gitName := "" -}}
{{- $gitEmail := "" -}}
{{- $credClaudeApi := "" -}}
{{- $credBuildkite := "" -}}
{{- $workProfile := false -}}
{{- if or (env "CI") (env "GITHUB_ACTIONS") -}}
{{- $gitName = env "GIT_USER_NAME" -}}
{{- $gitEmail = env "GIT_USER_EMAIL" -}}
{{- $workProfile = env "WORK_PROFILE" -}}
{{- else -}}
{{- $gitName = promptStringOnce . "git.name" "Git user.name" -}}
{{- $gitEmail = promptStringOnce . "git.email" "Git user.email" -}}
{{- $credClaudeApi = promptStringOnce . "credentials.claude_api" "1Password ref for Claude API" -}}
{{- $credBuildkite = promptStringOnce . "credentials.buildkite" "1Password ref for Buildkite" -}}
{{- $workProfile = promptBoolOnce . "work_profile" "Is this your work machine? y/N" -}}
{{- end -}}

# Source Directory Configuration
# Allows us to maintain Chezmoi outside of the default `~/.local/share/chezmoi/`.
# This enables storing the dotfiles repository in a custom location while still
# using chezmoi for management. The workingTree variable points to the repo root.
sourceDir = "{{ .chezmoi.workingTree }}"

[data]
work_profile = {{ $workProfile }}

# Data Section
# Variables defined here are available in all templates via the .data namespace.
# These values can be referenced in template files throughout the dotfiles repo.
[data.git]
# Git user configuration - prompted during initialization
# Used in git config templates and other version control settings
name = {{ $gitName | quote }}
email = {{ $gitEmail | quote }}

[onepassword]
cache = true

[data.credentials]
claude_api = {{ $credClaudeApi | quote }}
buildkite = {{ $credBuildkite | quote }}
