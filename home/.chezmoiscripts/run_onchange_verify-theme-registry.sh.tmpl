#!/usr/bin/env bash
# Cross-check that every tool key referenced in .chezmoidata/themes.yaml has
# a matching applier under home/dot_local/libexec/dotfiles/theme.d/, and vice
# versa. Apply fails with a readable error on drift.
#
# Also ensures the runtime state file exists by applying the catalog default
# on first apply, so tools that read the overlay (Ghostty's config-file) find
# a non-empty file.
#
# Hash inputs (re-fires when any of these change):
#   themes data:        {{ include ".chezmoidata/themes.yaml" | sha256sum }}
#   entrypoint:         {{ include "dot_local/bin/executable_theme" | sha256sum }}
#   lookup helper:      {{ include "dot_local/libexec/dotfiles/executable_theme-lookup" | sha256sum }}
#   tmux applier:       {{ include "dot_local/libexec/dotfiles/theme.d/executable_tmux" | sha256sum }}
#   nvim applier:       {{ include "dot_local/libexec/dotfiles/theme.d/executable_nvim" | sha256sum }}
#   ghostty applier:    {{ include "dot_local/libexec/dotfiles/theme.d/executable_ghostty" | sha256sum }}
#   c-powerline applier:{{ include "dot_local/libexec/dotfiles/theme.d/executable_claude-powerline" | sha256sum }}

set -o errexit -o nounset -o pipefail

theme_d="$HOME/.local/libexec/dotfiles/theme.d"
catalog="${XDG_CONFIG_HOME:-$HOME/.config}/theme/themes.json"

if [[ ! -d "$theme_d" ]]; then
  echo "verify-theme-registry: applier directory missing at $theme_d" >&2
  exit 1
fi

if [[ ! -f "$catalog" ]]; then
  echo "verify-theme-registry: catalog missing at $catalog" >&2
  exit 1
fi

# Read lines into arrays without mapfile so this works on bash 3.2 (default
# /bin/bash on macOS) as well as bash 4+.
read_lines() {
  local __arr=$1
  shift
  local IFS=$'\n' line
  eval "$__arr=()"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    eval "$__arr+=(\"\$line\")"
  done < <("$@")
}

# Tools referenced across every palette (union of keys).
# shellcheck disable=SC2016,SC2034 # jq filter; array filled via read_lines/eval
read_lines catalog_tools jq -r '[.palettes[] | keys[]] | unique[]' "$catalog"

# Appliers present on disk (basenames, sorted).
# shellcheck disable=SC2034 # array filled via read_lines/eval
read_lines applier_tools sh -c "find '$theme_d' -type f -perm -u+x -exec basename {} \\; | sort"

default=$(jq -r '.default' "$catalog")
if [[ -z "$default" || "$default" == "null" ]]; then
  echo "verify-theme-registry: catalog missing .default" >&2
  exit 1
fi

# shellcheck disable=SC2016,SC2034 # jq filter; array filled via read_lines/eval
read_lines default_tools jq -r --arg t "$default" '.palettes[$t] | keys[]' "$catalog"

# Every catalog tool reference (union) must have a matching applier.
missing_appliers=()
# shellcheck disable=SC2154 # filled by read_lines above
for tool in "${catalog_tools[@]}"; do
  found=0
  # shellcheck disable=SC2154 # filled by read_lines above
  for applier in "${applier_tools[@]}"; do
    [[ "$applier" == "$tool" ]] && { found=1; break; }
  done
  (( found )) || missing_appliers+=("$tool")
done

# Every applier must be in the default palette so fallback always resolves.
orphan_appliers=()
# shellcheck disable=SC2154 # filled by read_lines above
for applier in "${applier_tools[@]}"; do
  found=0
  # shellcheck disable=SC2154 # filled by read_lines above
  for tool in "${default_tools[@]}"; do
    [[ "$applier" == "$tool" ]] && { found=1; break; }
  done
  (( found )) || orphan_appliers+=("$applier")
done

if (( ${#missing_appliers[@]} )); then
  echo "verify-theme-registry: catalog references tools with no applier:" >&2
  printf '  - %s\n' "${missing_appliers[@]}" >&2
  echo "  expected at: $theme_d/<tool>" >&2
  exit 1
fi

if (( ${#orphan_appliers[@]} )); then
  echo "verify-theme-registry: appliers missing from the default palette '$default':" >&2
  printf '  - %s\n' "${orphan_appliers[@]}" >&2
  echo "  add a key for each in home/.chezmoidata/themes.yaml under palettes.$default" >&2
  exit 1
fi

# Apply the catalog default if no state file exists, so consumers of the
# overlay files (Ghostty's config-file, tmux source-file) find them on first
# boot of a fresh machine.
state_file="${XDG_STATE_HOME:-$HOME/.local/state}/theme/current"
if [[ ! -f "$state_file" ]]; then
  default=$(jq -r '.default' "$catalog")
  if [[ -n "$default" && "$default" != "null" ]]; then
    echo "verify-theme-registry: applying default theme '$default' (first apply)"
    "$HOME/.local/bin/theme" "$default" || true
  fi
fi
