#!/bin/bash

# mise config hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
# mise lock hash: {{ include "dot_config/mise/mise.lock" | sha256sum }}

[ -n "${DEBUG:-}" ] && set -o xtrace
set -o errexit
set -o nounset

# Only run mise if available
if ! command -v mise >/dev/null 2>&1; then
    echo "mise not found, skipping tool installation"
    exit 0
fi

echo "Installing global mise tools..."

# Authenticate to GitHub so mise (and the aqua backend it delegates to) get
# the 5000/hr authenticated rate limit instead of the 60/hr anonymous cap.
# CI sets GITHUB_TOKEN via the step env; on a developer machine, fall back
# to gh's stored auth token.
{{- if lookPath "gh" }}
if [ -z "${GITHUB_TOKEN:-}" ]; then
    GITHUB_TOKEN="$(gh auth token 2>/dev/null || true)"
    export GITHUB_TOKEN
fi
{{- end }}

mise install --yes

echo "Pruning unused mise tool versions and stale caches..."
mise prune --yes
mise cache prune

echo "Global mise tools installation complete"
