#!/bin/bash

export PLUGIN_DIR="$HOME/.config/sketchybar/plugins"
export ITEM_DIR="$HOME/.config/sketchybar/items"


# shellcheck disable=SC1091
source "$HOME/.config/sketchybar/colors.sh"
# shellcheck disable=SC1091
source "$HOME/.config/sketchybar/icons.sh"
# shellcheck disable=SC1091
source "$HOME/.config/sketchybar/vars.sh"

export PLUGIN_DIR="$HOME/.config/sketchybar/plugins"
export ITEM_DIR="$HOME/.config/sketchybar/items"
export EVENT_DIR="$HOME/.config/sketchybar/events"
displays=$(yabai -m query --displays)
displays_length=$(echo "$displays" | jq -r 'length')
export DISPLAY_COUNT=$displays_length

launchctl unload -F /System/Library/LaunchAgents/com.apple.OSDUIHelper.plist > /dev/null 2>&1 &

bar=(
  blur_radius=20
  border_width=1
  corner_radius=25
  display=all
  font_smoothing=false
  height=35
  margin=10
  notch_offset=0
  notch_width=0
  padding_left=10
  padding_right=10
  position=top
  shadow.drawing="$SHADOW"
  shadow=off
  sticky=off
  topmost=off
  y_offset=10
)

icon_defaults=(
  icon.align="center"
  icon.background.drawing=off
  icon.background.height="$SEGMENT_HEIGHT"
  icon.drawing=on
  icon.font="$ICON_FONT:Bold:15.0"
  icon.highlight=off
  icon.padding_left="$PADDINGS"
  icon.padding_right="$PADDINGS"
  icon.shadow.drawing=off
  icon.y_offset=0
)

background_defaults=(
  background.border_width="$SEGMENT_BORDER_WIDTH"
  background.clip=0.0
  background.corner_radius="$CORNER_RADIUS"
  background.height="$SEGMENT_HEIGHT"
  background.padding_left="$PADDINGS"
  background.padding_right="$PADDINGS"
  background.shadow.drawing=off
  background.y_offset=0
  drawing=on
)

popup_defaults=(
  popup.height=35
  popup.horizontal=false
  popup.blur_radius=20
  popup.y_offset=0
  popup.background.drawing=on
  popup.background.border_width="$POPUP_BORDER_WIDTH"
  popup.background.corner_radius="$POPUP_CORNER_RADIUS"
  popup.background.shadow.drawing="$SHADOW"
)

sketchybar --bar "${bar[@]}"
sketchybar --add event float_change

sketchybar --default \
  drawing=on \
  updates=when_shown \
  "${icon_defaults[@]}" \
  "${background_defaults[@]}" \
  "${popup_defaults[@]}"

label_template=(
  icon.drawing=off
  label.font="$LABEL_FONT:Regular:12.0"
  label.padding_right=5
  label.background.height="$SEGMENT_HEIGHT"
  click_script="$PLUGIN_DIR/toggle_bracket.sh"
  background.padding_left="$SEGMENT_SPACING"
  background.padding_right=0
  drawing=off
)

sep_template=(
  icon=" "
  drawing=off
)

sketchybar --add item label_template left \
  --set label_template "${label_template[@]}" \
  --add item sep_template left \
  --set sep_template "${sep_template[@]}"

