{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':semanticCommits',
    ':disableDependencyDashboard',
  ],
  timezone: 'America/New_York',
  platformCommit: 'enabled',
  configMigration: true,
  automerge: true,
  automergeStrategy: 'squash',
  prHourlyLimit: 2,
  labels: [
    'type:chore',
  ],
  enabledManagers: [
    'mise',
    'github-actions',
    'custom.regex',
    'custom.jsonata',
  ],
  lockFileMaintenance: {
    enabled: true,
    schedule: [
      'at any time',
    ],
  },
  mise: {
    managerFilePatterns: [
      '/^home/dot_config/mise/config\\.toml$/',
      '/^mise\\.toml$/',
    ],
  },
  'github-actions': {
    pinDigests: true,
    managerFilePatterns: [
      '/^\\.github/workflows/.*\\.ya?ml$/',
    ],
  },
  packageRules: [
    {
      matchManagers: [
        'mise',
      ],
      extractVersion: '^v?(?<version>.+)$',
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^home/dot_config/dotfiles/cli-versions\\.toml$/',
      ],
      matchStrings: [
        '^cosign\\s*=\\s*"(?<currentValue>v?[^"]+)"',
      ],
      depNameTemplate: 'sigstore/cosign',
      datasourceTemplate: 'github-releases',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^hk\\.pkl$/',
      ],
      matchStrings: [
        'github\\.com/jdx/hk/releases/download/(?<currentValue>v[^/]+)/hk@[^#"]+',
      ],
      depNameTemplate: 'jdx/hk',
      datasourceTemplate: 'github-releases',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^home/dot_config/go-tools/tools\\.txt$/',
      ],
      matchStrings: [
        '^(?<depName>[^\\s@]+)@(?<currentValue>v?[^\\s#]+)',
      ],
      datasourceTemplate: 'go',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^home/dot_config/node-tools/tools\\.txt$/',
      ],
      matchStrings: [
        '^(?<depName>[^@\\n]+)@(?<currentValue>[^\\n#]+)',
      ],
      datasourceTemplate: 'npm',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^home/\\.chezmoiexternal\\.toml\\.tmpl$/',
      ],
      matchStrings: [
        'catppuccin/ghostty/archive/(?<currentDigest>[a-f0-9]{7,40})\\.tar\\.gz',
      ],
      datasourceTemplate: 'git-refs',
      currentValueTemplate: 'main',
      depNameTemplate: 'catppuccin/ghostty',
      packageNameTemplate: 'https://github.com/catppuccin/ghostty',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^home/\\.chezmoiexternal\\.toml\\.tmpl$/',
      ],
      matchStrings: [
        'ohmyzsh/ohmyzsh/archive/(?<currentDigest>[a-f0-9]{7,40})\\.tar\\.gz',
      ],
      datasourceTemplate: 'git-refs',
      currentValueTemplate: 'master',
      depNameTemplate: 'ohmyzsh/ohmyzsh',
      packageNameTemplate: 'https://github.com/ohmyzsh/ohmyzsh',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^home/\\.chezmoiexternal\\.toml\\.tmpl$/',
      ],
      matchStrings: [
        'zsh-users/zsh-autosuggestions/archive/(?<currentDigest>[a-f0-9]{7,40})\\.tar\\.gz',
      ],
      datasourceTemplate: 'git-refs',
      currentValueTemplate: 'master',
      depNameTemplate: 'zsh-users/zsh-autosuggestions',
      packageNameTemplate: 'https://github.com/zsh-users/zsh-autosuggestions',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^home/\\.chezmoiexternal\\.toml\\.tmpl$/',
      ],
      matchStrings: [
        'zsh-users/zsh-syntax-highlighting/archive/(?<currentDigest>[a-f0-9]{7,40})\\.tar\\.gz',
      ],
      datasourceTemplate: 'git-refs',
      currentValueTemplate: 'master',
      depNameTemplate: 'zsh-users/zsh-syntax-highlighting',
      packageNameTemplate: 'https://github.com/zsh-users/zsh-syntax-highlighting',
    },
    {
      customType: 'jsonata',
      fileFormat: 'yaml',
      managerFilePatterns: [
        '/^home/\\.chezmoidata/tmux-plugins\\.yaml$/',
      ],
      matchStrings: [
        'tmuxPlugins.{ "depName": repo, "currentValue": ref, "currentDigest": commit }',
      ],
      datasourceTemplate: 'git-refs',
      packageNameTemplate: 'https://github.com/{{{depName}}}',
    },
  ],
}
