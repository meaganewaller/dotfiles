#!/usr/bin/env bash
#
# sync-claude-extras - Reconcile declared Claude Code extras (plugin marketplaces,
# plugins, MCP servers) into the user-scope install.
#
# Declared state is read from chezmoi data:
#  .claudeData          committed, public   (home/.chezmoidata/claude.yaml)
#  .claudeExternalExtra machine-local       ([data.claudeExternalExtra] in ~/.config/chezmoi/chezmoi.toml)
#
# Current (installed) state is read from Claude Code's own JSON state files
# (~/.claude/plugins/known_marketplaces.json + installed_plugins.json, and
# ~/.claude.json for MCP) because the `claude` CLI no longer exposes it headlessly.
# Changes are still realized through the `claude` CLI — the single writer of
# extraKnownMarketplaces / enabledPlugins / mcpServers — but note those writes
# currently require an interactive (TTY) claude session.
#
# Idempotent and additive: only missing items are added. Items installed but not
# declared are reported, never removed, unless --prune is given. Plugins/marketplaces
# at "managed" scope (admin-pushed) are left untouched. See docs/agents/claude-code.md
# for more details.
#
# Usage: sync-claude-extras [--check] [--prune]
# 	--check   dry run: report what would be done, don't change anything
# 	--prune   remove any extras that are not declared in the data

[[ -n "${DEBUG:-}" ]] && set -o xtrace
set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

# Claude Code records installed state in plain JSON here (the CLI no longer
# exposes it headlessly). Overridable for tests via CLAUDE_PLUGINS_DIR.
PLUGINS_DIR="${CLAUDE_PLUGINS_DIR:-${HOME}/.claude/plugins}"
MARKETPLACES_FILE="${PLUGINS_DIR}/known_marketplaces.json"
INSTALLED_PLUGINS_FILE="${PLUGINS_DIR}/installed_plugins.json"

CHECK=false
PRUNE=false

for arg in "$@"; do
  case "${arg}" in
  --check) CHECK=true ;;
  --prune) PRUNE=true ;;
  *)
    printf 'error: unknown argument: %s\n' "${arg}" >&2
    printf 'usage: sync-claude-extras [--check] [--prune]\n' >&2
    exit 2
    ;;
  esac
done

log() { printf '%s\n' "$*"; }
warn() { printf '%s\n' "$*" >&2; }

require_command() {
  command -v "$1" >/dev/null 2>&1
}

# Run a mutating claude command unless --check; log failures and keep going so a
# single bad item (network/auth) never aborts `chezmoi apply`.
run_claude() {
  if [[ "${CHECK}" == true ]]; then
    log "  [check] would run: claude $*"
    return 0
  fi
  if ! claude "$@"; then
    warn "  could not run 'claude $*' — plugin/MCP writes need an interactive"
    warn "  claude session (the CLI is not headless); run it manually. Continuing."
    return 1
  fi
}

# Merge a declared list from base + machine-local extras under the given path
# (e.g. ".marketplaces"). Emits one compact JSON value per line. The argument is
# interpolated into the jq program, so call sites must pass a literal path suffix.
declared() {
  jq -c "((.claudeData${1} // []) + (.claudeExternalExtra${1} // []))[]" <<<"${DATA}"
}

# Marketplaces built into Claude Code: present on every install, not addable or
# removable by us, so they must never be reported as drift (nor pruned). Extend
# this list if Claude Code ships more built-ins.
BUILTIN_MARKETPLACES='claude-plugins-official'

is_builtin_marketplace() {
  grep -qxF "$1" <<<"${BUILTIN_MARKETPLACES}"
}

reconcile_marketplaces() {
  log 'marketplaces:'
  local existing declared_names name repo
  # Installed marketplaces come from Claude Code's state file (keys are names).
  existing="$(jq -r 'keys[]' "${MARKETPLACES_FILE}" 2>/dev/null || true)"

  declared_names=''
  while IFS=$'\t' read -r name repo; do
    [[ -z "${name}" ]] && continue
    declared_names+="${name}"$'\n'
    if grep -qxF "${name}" <<<"${existing}"; then
      log "  ok: ${name}"
    else
      log "  + add ${name} (${repo})"
      run_claude plugin marketplace add "${repo}" || true
    fi
  done < <(declared '.marketplaces' | jq -r '[.name, .repo] | @tsv')

  prune_extra 'marketplace' "${existing}" "${declared_names}"
}

reconcile_plugins() {
  log 'plugins:'
  local existing_ids user_ids declared_ids id
  # Installed plugins come from Claude Code's state file, keyed "<id>@<marketplace>";
  # each value is an array of install records carrying scope.
  existing_ids="$(jq -r '(.plugins // {}) | keys[]' "${INSTALLED_PLUGINS_FILE}" 2>/dev/null || true)"
  # Only user-scope ids are eligible for prune; managed/project are left alone.
  user_ids="$(jq -r '(.plugins // {}) | to_entries[] | select(any(.value[]?; .scope == "user")) | .key' "${INSTALLED_PLUGINS_FILE}" 2>/dev/null || true)"

  declared_ids=''
  while IFS= read -r id; do
    [[ -z "${id}" ]] && continue
    declared_ids+="${id}"$'\n'
    if grep -qxF "${id}" <<<"${existing_ids}"; then
      log "  ok: ${id}"
    else
      log "  + install ${id}"
      run_claude plugin install "${id}" --scope user || true
    fi
  done < <(declared '.plugins' | jq -r '.') # plugins are strings; unquote the compact JSON

  prune_extra 'plugin' "${user_ids}" "${declared_ids}"
}

reconcile_mcp() {
  log 'mcp servers:'
  local claude_json existing name server
  claude_json="${HOME}/.claude.json"
  existing="$(jq -r '.mcpServers // {} | keys[]' "${claude_json}" 2>/dev/null || true)"

  local declared_names=''
  while IFS= read -r server; do
    [[ -z "${server}" ]] && continue
    name="$(jq -r '.name' <<<"${server}")"
    declared_names+="${name}"$'\n'
    if grep -qxF "${name}" <<<"${existing}"; then
      log "  ok: ${name}"
    else
      log "  + add ${name}"
      mcp_add "${server}" || true
    fi
  done < <(declared '.mcpServers')

  prune_extra 'mcp' "${existing}" "${declared_names}"
}

# Build and run `claude mcp add` from a server JSON object.
# http/sse: claude mcp add -s user -t <t> [-H ...] <name> <url>
# stdio:    claude mcp add -s user -t stdio [-e ...] <name> -- <command> [args...]
mcp_add() {
  local server="$1" name transport
  name="$(jq -r '.name' <<<"${server}")"
  transport="$(jq -r '.transport // "stdio"' <<<"${server}")"

  local cmd=(mcp add --scope user --transport "${transport}")

  local kv
  while IFS= read -r kv; do
    [[ -n "${kv}" ]] && cmd+=(--env "${kv}")
  done < <(jq -r '(.env // {}) | to_entries[] | "\(.key)=\(.value)"' <<<"${server}")

  while IFS= read -r kv; do
    [[ -n "${kv}" ]] && cmd+=(--header "${kv}")
  done < <(jq -r '(.headers // {}) | to_entries[] | "\(.key): \(.value)"' <<<"${server}")

  if [[ "${transport}" == "stdio" ]]; then
    local command_bin
    command_bin="$(jq -r '.command' <<<"${server}")"
    cmd+=("${name}" -- "${command_bin}")
    local a
    while IFS= read -r a; do
      cmd+=("${a}")
    done < <(jq -r '(.args // [])[]' <<<"${server}")
  else
    cmd+=("${name}" "$(jq -r '.url' <<<"${server}")")
  fi

  run_claude "${cmd[@]}"
}

# Report (and with --prune, remove) user-scope items installed but not declared.
# kind is one of: marketplace | plugin | mcp
prune_extra() {
  local kind="$1" existing="$2" declared_names="$3" item
  while IFS= read -r item; do
    [[ -z "${item}" ]] && continue
    grep -qxF "${item}" <<<"${declared_names}" && continue
    # Built-in marketplaces are not ours to manage — never flag or prune them.
    [[ "${kind}" == marketplace ]] && is_builtin_marketplace "${item}" && continue
    if [[ "${PRUNE}" == true ]]; then
      log "  - prune ${kind} ${item}"
      case "${kind}" in
      marketplace) run_claude plugin marketplace remove "${item}" || true ;;
      plugin) run_claude plugin uninstall "${item}" || true ;;
      mcp) run_claude mcp remove "${item}" || true ;;
      esac
    else
      log "  drift: ${kind} ${item} is installed but not declared (use --prune to remove)"
    fi
  done <<<"${existing}"
}

main() {
  if ! require_command claude; then
    warn 'claude not found in PATH — skipping extras sync'
    exit 0
  fi
  require_command jq || {
    warn 'jq not found in PATH — cannot reconcile extras'
    exit 1
  }

  # Authenticate to GitHub for private marketplaces (machine-local extras may
  # reference one). The reconciler issues many claude calls, so export rather
  # than the inline form used for one-shot commands elsewhere.
  if [[ -z "${GITHUB_TOKEN:-}" ]] && require_command gh; then
    GITHUB_TOKEN="$(gh auth token 2>/dev/null)" || true
    [[ -n "${GITHUB_TOKEN:-}" ]] && export GITHUB_TOKEN
  fi

  DATA="$(chezmoi data --format json)"

  [[ "${CHECK}" == true ]] && log '(dry run — no changes will be made)'
  # One reconciler per type — the claude CLI surface differs per type. To add a
  # type: add a key in claude.yaml, a reconcile_* function, and a
  # prune_extra case.
  reconcile_marketplaces
  reconcile_plugins
  reconcile_mcp
  log 'done'
}

main "$@"
