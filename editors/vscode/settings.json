{
  // "editor.fontLigatures": "'ss01'",
  "editor.lineHeight": 22,
  "editor.scrollBeyondLastLine": false,
  "files.associations": {
    "zshrc": "shellscript"
  },
  "files.autoSave": "onFocusChange",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "telemetry.enableTelemetry": false,
  "telemetry.enableCrashReporter": false,
  "terminal.integrated.shell.osx": "/usr/local/bin/fish",
  "workbench.colorTheme": "Fluffy Theme",
  "workbench.colorCustomizations": {
    "activityBar.background": "#333842",
    "badge.background": "#528BFF",
    "editorLineNumber.foreground": "#636D83",
    "editorLineNumber.activeForeground": "#D7DAE0",
    "sideBarSectionHeader.background": "#333842",
    "terminal.ansiBlack": "#293340",
    "terminal.ansiBlue": "#4CB2FF",
    "terminal.ansiCyan": "#2DCED0",
    "terminal.ansiGreen": "#61BA86",
    "terminal.ansiMagenta": "#BE86E3",
    "terminal.ansiRed": "#E17E85",
    "terminal.ansiWhite": "#CDD2E9",
    "terminal.ansiYellow": "#FFEC8E",
    "terminal.ansiBrightBlack": "#546386",
    "terminal.ansiBrightBlue": "#4CB2FF",
    "terminal.ansiBrightCyan": "#2DCED0",
    "terminal.ansiBrightGreen": "#61BA86",
    "terminal.ansiBrightMagenta": "#BE86E3",
    "terminal.ansiBrightRed": "#E17E85",
    "terminal.ansiBrightWhite": "#CDD2E9",
    "terminal.ansiBrightYellow": "#FFB68E"
  },
  "gitlens.views.repositories.location": "gitlens",
  "gitlens.views.fileHistory.location": "gitlens",
  "gitlens.views.lineHistory.location": "gitlens",
  "gitlens.views.compare.location": "gitlens",
  "gitlens.views.search.location": "gitlens",
  "selectinsidesidebar.defaultStyle": {
    "overviewRulerColor": "lightgreen"
  },
  "todo-tree.general.statusBar": "tags",
  "todo-tree.general.tags": ["TODO", "FIXME", "BUG"],
  "todo-tree.regex.regex": "((//|#|<!--|;|/\\*|^)\\s*[!?]?\\s*($TAGS)|^\\s*- \\[ \\])",
  "todo-tree.ripgrep.ripgrep": "/usr/local/bin/rg",
  "todo-tree.tree.flat": true,
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.tree.showInExplorer": false,
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "foreground": "white",
      "background": "green",
      "iconColour": "green",
      "rulerColour": "green"
    },
    "FIXME": {
      "icon": "alert",
      "foreground": "black",
      "background": "yellow",
      "iconColour": "yellow",
      "rulerColour": "yellow"
    },
    "BUG": {
      "icon": "bug",
      "foreground": "white",
      "background": "red",
      "iconColour": "red",
      "rulerColour": "red"
    }
  },
  "projectManager.git.baseFolders": [
  ],
  "projectManager.git.maxDepthRecursion": 1,
  "projectManager.showProjectNameInStatusBar": false,
  "github.username": "meaganewaller",
  "color-highlight.markerType": "dot-before",
  "git-graph.fetchAvatars": true,
  "git-graph.showStatusBarItem": false,
  "commands.commands": [
    {
      "text": "$(gear)",
      "command": "workbench.action.openGlobalSettings",
      "tooltip": "Settings"
    },
    {
      "text": "$(terminal)",
      "command": "workbench.action.terminal.focus",
      "tooltip": "Terminal"
    },
    {
      "text": "$(package)",
      "command": "workbench.action.tasks.build",
      "tooltip": "Run default build task"
    },
    {
      "text": "$(beaker)",
      "command": "workbench.action.tasks.test",
      "tooltip": "Run default tests"
    },
    {
      "text": "$(graph)",
      "command": "git-graph.view",
      "tooltip": "Git Graph"
    },
    {
      "text": "$(project)",
      "command": "glo.open",
      "tooltip": "GitKraken Glo"
    }
  ],
  "python.linting.flake8Enabled": true,
  "python.linting.flake8Path": "/usr/local/bin/flake8",
  "python.linting.pylintEnabled": false,
  "material-icon-theme.files.associations": {
    "*.toml": "toml",
    ".coverage": "codecov",
    ".pre-commit-config.yaml": "precommit",
    "Cargo.lock": "cargo",
    "Cargo.toml": "cargo",
    "pre-commit-config.yaml": "precommit",
    "Preferences.sublime-settings": "sublime",
    "pyproject.toml": "python-misc",
    "TODO": "todo",
    ".tool-versions": "settings",
    "tox.ini": "tox"
  },
  "material-icon-theme.folders.associations": {
    "git": "git",
    "profiles": "meta",
    "vscode": "vscode"
  },
  "commentAnchors.workspace.excludeFiles": "**/{node_modules,.git,.idea,.tox,.venv,target,out,build,vendor}/**/*",
  "commentAnchors.scrollPosition": "center",
  "commentAnchors.tags.sortMethod": "type",
  "commentAnchors.tags.list": [
    {
      "tag": "TODO",
      "iconColor": "green",
      "scope": "workspace"
    },
    {
      "tag": "FIXME",
      "iconColor": "yellow",
      "scope": "workspace"
    },
    {
      "tag": "BUG",
      "iconColor": "red",
      "scope": "workspace"
    }
  ],
  "vscode_custom_css.imports": [


    "file:///Users/meagan/.vscode/custom.css"
  ],
  "todo.statistics.statusbar.enabled": true,
  "workbench.commandPalette.experimental.suggestCommands": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "window.zoomLevel": 2,
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "redhat.telemetry.enabled": true,
  "git.openRepositoryInParentFolders": "always",
  "explorer.confirmDelete": false,
  "editor.fontFamily": "SpaceMono Nerd Font Mono,SpaceMono Nerd Font,VictorMono Nerd Font Mono,VictorMono Nerd Font",
  "window.confirmSaveUntitledWorkspace": false,
  "editor.fontSize": 16,
  "workbench.sideBar.location": "right",
  "workbench.iconTheme": "vscode-celestial-magic-girl-icon-theme",
  "editor.tabSize": 2,
  "terminal.integrated.automationProfile.osx": {

  },
  "terminal.integrated.inheritEnv": false,
  "workbench.editor.enablePreview": false,
  "editor.minimap.enabled": false,
  "rubyLsp.formatter": "none",
  "workbench.productIconTheme": "bongocat"
}
